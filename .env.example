# Trilytics MAI pipeline — optional environment overrides.
#
# The pipeline works WITHOUT any .env: by default it reads credentials from
# the git-ignored Credentials/ folder (see README "Credentials / API keys").
# These variables exist for overrides and CI-style setups.
#
# Usage: cp .env.example .env, fill values, then `source .env` before running
# (plain shell variables — the pipeline does not auto-load this file).

# Path to a Firebase Admin SDK service-account JSON.
# Default: Credentials/Firebase_Service_Account.json
# Get one: Firebase console -> Project settings -> Service accounts
#          -> Generate new private key  (project: medicine-attractive-index)
#TRILYTICS_FIREBASE_CREDENTIALS=/absolute/path/to/service_account.json

# data.gov.in API key (source D — NFHS-5 district factsheet).
# Default: read from Credentials/DATA_GOV_IN_API_KEY.json -> data_gov_in.api_key
# Register free at https://www.data.gov.in/apis (one key works platform-wide).
#DATA_GOV_IN_API_KEY=

# Limit the PMJAY hospital scraper to the first N states (testing only).
#PMJAY_STATE_LIMIT=2
