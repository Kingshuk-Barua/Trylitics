# Trilytics MAI pipeline — environment template.
#
# Copy to .env and fill in the values:   cp .env.example .env
# pipeline/config.py auto-loads .env on import (no `source` needed, no extra
# dependency). Real shell environment variables always override .env.
#
# Every secret can be supplied here, so the pipeline runs on ANY machine or CI
# runner with NO local Credentials/ folder. If a value is left unset, config.py
# falls back to the git-ignored Credentials/ folder.
#
# NEVER commit the filled-in .env — it is git-ignored via .gitignore.
# =====================================================================

# --- data.gov.in (source D: NFHS-5 district factsheet) ---------------
# One platform-wide key. Register free at https://www.data.gov.in/apis
DATA_GOV_IN_API_KEY=

# --- Firebase Admin SDK (required to publish to Firestore) -----------
# Preferred: paste the WHOLE service-account JSON on one line, single-quoted
# (single quotes keep the \n escapes in private_key intact). Base64 of the
# JSON is also accepted.
#   Firebase console -> Project settings -> Service accounts
#   -> Generate new private key   (project: medicine-attractive-index)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional — usually inferred from the JSON above:
FIREBASE_PROJECT_ID=
# ...or, instead of the JSON blob, point at a key file on disk:
#FIREBASE_CREDENTIALS_PATH=/absolute/path/to/service_account.json

# --- Google Cloud service account (OPTIONAL Sheets / Drive layer) -----
# Whole GCP service-account JSON on one line, single-quoted (or base64).
GOOGLE_SERVICE_ACCOUNT_JSON=
# ...or a path (this is the standard Google env var):
#GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google_service_account.json

# --- Google Sheets (OPTIONAL collaborative curation grid) ------------
GOOGLE_SHEET_API_KEY=
GOOGLE_SHEET_LINK=

# --- Optional knobs ---------------------------------------------------
#PMJAY_STATE_LIMIT=2                 # test PMJAY on the first N states only
#FIRESTORE_DAILY_WRITE_CAP=15000    # Spark free-tier daily write headroom
#TRILYTICS_USER_AGENT=              # override the polite HTTP User-Agent

# --- Advanced (rarely needed) ----------------------------------------
#TRILYTICS_ENV_FILE=/absolute/path/to/.env         # load a different .env
#TRILYTICS_CREDENTIALS_DIR=/absolute/path/to/creds # relocate the fallback folder
